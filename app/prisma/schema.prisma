generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model a_recibo_pago {
  id                   Int                  @id @default(autoincrement())
  cliente_id           Int
  fecha_introduccion   DateTime             @db.Date
  fecha                DateTime             @db.Date
  numero_factura       String?              @db.VarChar(60)
  monto                Decimal              @db.Decimal(10, 2)
  descripcion          String?              @db.VarChar(254)
  e_estructura_cliente e_estructura_cliente @relation(fields: [cliente_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_23679AA8DE734E51")

  @@index([cliente_id], map: "IDX_23679AA8DE734E51")
}

model b_consecutivo_empresa_banco {
  id                   Int                   @id @default(autoincrement())
  banco_id             Int?
  empresa_id           Int?
  consecutivo          Int
  e_estructura_empresa e_estructura_empresa? @relation(fields: [empresa_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_E8669A36521E1991")
  n_banco              n_banco?              @relation(fields: [banco_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_E8669A36CC04A73E")

  @@index([empresa_id], map: "IDX_E8669A36521E1991")
  @@index([banco_id], map: "IDX_E8669A36CC04A73E")
}

model b_pago_excluido {
  id              Int         @id @default(autoincrement())
  empleado_id     Int?
  monto           Decimal     @db.Decimal(10, 2)
  tipo_planilla   String?     @db.VarChar(20)
  id_foraneo      Int
  estado          String?     @db.VarChar(20)
  fecha_creado    DateTime    @db.DateTime(0)
  fecha_pagado    DateTime?   @db.DateTime(0)
  usuario_inserta String?     @db.VarChar(64)
  usuario_paga    String?     @db.VarChar(64)
  c_empleado      c_empleado? @relation(fields: [empleado_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_E34A23BC952BE730")

  @@index([empleado_id], map: "IDX_E34A23BC952BE730")
}

